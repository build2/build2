: set-version
:
{
  $* <<EOI >>EOO
  shellscript.syntax = 2
  if true
  {
    cmd
  }
  EOI
  ? true
  cmd
  EOO
}

: unsupported-version
:
{
  $* <<EOI 2>>EOE != 0
  shellscript.syntax = 1
  if true
    cmd
  end
  EOI
  shellscript:11:22: error: expected syntax version in range [2 2] instead of '1'
  EOE
}

: invalid-assignment
:
{
  $* <<EOI 2>>EOE != 0
  shellscript.syntax += 2
  cmd
  EOI
  shellscript:11:20: error: expected '=' instead of '+='
  EOE
}

: no-version
:
{
  $* <<EOI 2>>EOE != 0
  shellscript.syntax =
  cmd
  EOI
  shellscript:11:21: error: expected syntax version instead of <newline>
  EOE
}

: invalid-version
:
{
  $* <<EOI 2>>EOE != 0
  shellscript.syntax = foo
  cmd
  EOI
  shellscript:11:22: error: expected syntax version in range [2 2] instead of 'foo'
  EOE
}

: trailing-junk
:
{
  $* <<EOI 2>>EOE != 0
  shellscript.syntax = 2 foo
  cmd
  EOI
  shellscript:11:24: error: expected newline after syntax version
  EOE
}

: non-first-line
:
{
  $* <<EOI 2>>EOE != 0
  foo = bar
  shellscript.syntax = 1
  cmd
  EOI
  shellscript:12:1: error: variable shellscript.syntax should be assigned on first line of the script
  EOE
}
