: set-version
:
{
  $* <<EOI >>EOO
  buildscript.syntax = 1
  if true
    cmd
  end
  EOI
  ? true
  cmd
  EOO
}

: invalid-assignment
:
{
  $* <<EOI 2>>EOE != 0
  buildscript.syntax += 1
  cmd
  EOI
  buildfile:11:20: error: expected '=' instead of '+='
  EOE
}

: no-version
:
{
  $* <<EOI 2>>EOE != 0
  buildscript.syntax =
  cmd
  EOI
  buildfile:11:21: error: expected syntax version instead of <newline>
  EOE
}

: invalid-version
:
{
  $* <<EOI 2>>EOE != 0
  buildscript.syntax = foo
  cmd
  EOI
  buildfile:11:22: error: expected syntax version in range [1 2] instead of 'foo'
  EOE
}

: trailing-junk
:
{
  $* <<EOI 2>>EOE != 0
  buildscript.syntax = 1 foo
  cmd
  EOI
  buildfile:11:24: error: expected newline after syntax version
  EOE
}

: non-first-line
:
{
  $* <<EOI 2>>EOE != 0
  foo = bar
  buildscript.syntax = 1
  cmd
  EOI
  buildfile:12:1: error: variable buildscript.syntax should be assigned on first line of the script
  EOE
}
