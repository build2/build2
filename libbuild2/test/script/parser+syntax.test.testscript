# file      : libbuild2/test/script/parser+syntax.test.testscript
# license   : MIT; see accompanying LICENSE file

: set-version
:
{
  $* <<EOI >>EOO
  testscript.syntax = 1
  if true
    cmd
  end
  EOI
  ? true
  cmd
  EOO
}

: invalid-assignment
:
{
  $* <<EOI 2>>EOE != 0
  testscript.syntax += 1
  cmd
  EOI
  testscript:1:19: error: expected '=' instead of '+='
  EOE
}

: no-version
:
{
  $* <<EOI 2>>EOE != 0
  testscript.syntax =
  cmd
  EOI
  testscript:1:20: error: expected syntax version instead of <newline>
  EOE
}

: invalid-version
:
{
  $* <<EOI 2>>EOE != 0
  testscript.syntax = foo
  cmd
  EOI
  testscript:1:21: error: expected syntax version in range [1 2] instead of 'foo'
  EOE
}

: trailing-junk
:
{
  $* <<EOI 2>>EOE != 0
  testscript.syntax = 1 foo
  cmd
  EOI
  testscript:1:23: error: expected newline after syntax version
  EOE
}

: non-first-line
:
{
  $* <<EOI 2>>EOE != 0
  foo = bar
  testscript.syntax = 1
  cmd
  EOI
  testscript:2:1: error: variable testscript.syntax should be assigned on first line of the script
  EOE
}
